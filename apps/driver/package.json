{
  "name": "smartkiosk-driver",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:capacitor": "tsc && vite build --mode capacitor",
    "preview": "vite preview",
    "cap": "npm exec cap",
    "cap:sync": "npm run build:capacitor && npm exec cap sync android",
    "cap:add:android": "npm exec cap add android"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/camera": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/network": "^8.0.0",
    "@supabase/supabase-js": "^2.39.0",
    "dexie": "^3.2.4",
    "dexie-react-hooks": "^1.1.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0"
  },
  "overrides": {
    "glob": "^11.1.0",
    "tar": "^7.5.11"
  },
  "devDependencies": {
    "@capacitor/cli": "8.3.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.3.0",
    "vite": "^6.4.1"
  }
}
